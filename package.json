{
  "name": "tlauncher",
  "version": "0.1.0",
  "description": "Tomcat 기반 WAR 프로젝트의 빌드, 배포, 실행을 위한 데스크톱 런처",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "generate:icons": "node scripts/generate-icons.js",
    "dist:win": "node scripts/dist-win.js",
    "dist:win:builder": "electron-builder --win dir"
  },
  "keywords": [
    "electron",
    "tomcat",
    "launcher"
  ],
  "author": "ghbseo",
  "license": "MIT",
  "devDependencies": {
    "debug": "^4.4.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.ghbseo.tlauncher",
    "productName": "tLauncher",
    "copyright": "Copyright © 2026 ghbseo",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "tLauncher-${version}-win-${arch}.${ext}",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    }
  }
}
